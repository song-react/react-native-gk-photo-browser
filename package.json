{
  "name": "react-native-gk-photo-browser",
  "version": "0.0.1",
  "description": "react-native-gk-photo-browser",
  "main": "lib/index.js",
  "module": "lib/index.js",
  "types": "lib/index.d.ts",
  "react-native": "lib/index.js",
  "source": "src/index.ts",
  "files": [
    "src",
    "react-native.config.js",
    "lib",
    "nitrogen",
    "ios/**/*.{h,m,mm}",
    "cpp/**/*.{h,hpp,c,cpp,mm}",
    "nitro.json",
    "*.podspec",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit false",
    "specs": "tsc --noEmit false && nitrogen --logLevel=debug && bun run scripts/fix-ios-autolinking.mjs"
  },
  "keywords": [
    "react-native",
    "nitro",
    "gk-photo-browser"
  ],
  "license": "MIT",
  "devDependencies": {
    "@react-native/eslint-config": "0.83.0",
    "@types/react": "^19.1.3",
    "nitrogen": "^0.33.2",
    "react": "19.2.0",
    "react-native": "0.83.0",
    "react-native-nitro-modules": "^0.33.2",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*",
    "react-native-nitro-modules": "*"
  },
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false,
    "semi": false
  }
}
